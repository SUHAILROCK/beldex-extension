{
  "manifest_version": 3,
  "name": "BelScope",
  "version": "1.0.0",
  "description": "BelScope — Live BDX price, charts, network stats, and BNS checker for the Beldex ecosystem.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "BelScope",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": [
    "storage",
    "alarms",
    "sidePanel"
  ],
  "host_permissions": [
    "https://api.coingecko.com/*",
    "https://bdx-companion-api.vercel.app/*"
  ]
}
