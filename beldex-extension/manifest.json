{
  "manifest_version": 3,
  "name": "Beldex Companion",
  "version": "1.0.0",
  "description": "Live BDX price, network stats, BNS checker, and privacy alerts for the Beldex ecosystem.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Beldex Companion",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.binance.com/*",
        "https://www.coinbase.com/*",
        "https://www.kucoin.com/*",
        "https://www.bybit.com/*",
        "https://www.okx.com/*",
        "https://www.gate.io/*",
        "https://www.mexc.com/*",
        "https://www.bitget.com/*",
        "https://www.crypto.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": [
    "storage",
    "alarms",
    "activeTab",
    "sidePanel"
  ],
  "host_permissions": [
    "https://api.coingecko.com/*",
    "https://bdx-companion-api.vercel.app/*",
    "https://explorer.beldex.io/*"
  ]
}
